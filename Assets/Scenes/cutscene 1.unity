  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041E\u0421\u041D\u041E\u0412\u0410\u041D\u041E \u041D\u0410 \u0420\u041E\u041C\u0410\u041D\u0415\r\n\u0424.
    \u041C. \u0414\u041E\u0421\u0422\u041E\u0415\u0412\u0421\u041A\u041E\u0413\u041E\r\n\xAB\u0411\u0420\u0410\u0422\u042C\u042F
    \u041A\u0410\u0420\u0410\u041C\u0410\u0417\u041E\u0412\u042B\xBB\n\n\n\n\u0420\u0410\u0417\u0420\u0410\u0411\u041E\u0422\u041A\u0410
    \u0418 \u0421\u0426\u0415\u041D\u0410\u0420\u0418\u0419\n\n- \u043C\u044B, \u043A\u0442\u043E
    \u0436\u0435 \u0435\u0449\u0435?\n\n\n\n\u041E\u0417\u0412\u0423\u0427\u041A\u0410
    \u0418 \u0417\u0412\u0423\u041A\n\n\u0410\u043B\u0435\u043A\u0441\u0435\u0439
    \u2014 \u0420\u043E\u0440\u0448\u0430\u0445\r\n\u0418\u0432\u0430\u043D \u2014
    \u0414\u043E\u043C\u0438\u043D\u0438\u043A \u0422\u043E\u0440\u0435\u0442\u0442\u043E
    \r\n\u0421\u043C\u0435\u0440\u0434\u044F\u043A\u043E\u0432 \u2014 \u0422\u0430\u043D\u043E\u0441\r\n\u041A\u0430\u043F\u0438\u0442\u0430\u043D
    \u041C\u043E\u0440\u0433\u0430\u043D \u2014 \u0410\u0433\u0435\u043D\u0442 \u0421\u043C\u0438\u0442
    \n\n\n\n\u041E\u0421\u041E\u0411\u0410\u042F \u0411\u041B\u0410\u0413\u041E\u0414\u0410\u0420\u041D\u041E\u0421\u0422\u042C\n\n\u0414\u043E\u0441\u0442\u0430\u0432\u0449\u0438\u043A\u0443
    \u043F\u0438\u0446\u0446\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u0432\u0451\u0437
    \u0443\u0436\u0438\u043D \u0432 3 \u0447\u0430\u0441\u0430 \u043D\u043E\u0447\u0438
    \u0438 \u043D\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u043B \u043B\u0438\u0448\u043D\u0438\u0445
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432\r\n\r\n\u041A\u043E\u0444\u0435\u0438\u043D\u0443
    \u2014 \u0431\u0435\u0437 \u043D\u0435\u0433\u043E \u044D\u0442\u043E\u0442 \u043F\u0440\u043E\u0435\u043A\u0442
    \u0431\u044B\u043B \u0431\u044B \u0441\u0434\u0430\u043D \u0447\u0435\u0440\u0435\u0437
    \u0434\u0435\u043D\u044C\r\n\r\n\u041A\u043D\u043E\u043F\u043A\u0435 \xABUndo\xBB
    \u2014 \u0442\u044B \u0431\u044B\u043B\u0430 \u043D\u0430\u0448\u0435\u0439 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0434\u0435\u0436\u0434\u043E\u0439\r\n\r\nDeepSeek \u2014 \u0437\u0430
    \u043F\u043E\u043C\u043E\u0449\u044C \u0441\u043E \u0441\u0446\u0435\u043D\u0430\u0440\u0438\u0435\u043C,
    \u043C\u043E\u043D\u043E\u043B\u043E\u0433\u0430\u043C\u0438 \u0438 \u0437\u0430
    \u044D\u0442\u0443 \u0448\u0443\u0442\u043A\u0443\n\n\u0421\u041F\u0410\u0421\u0418\u0411\u041E
    \u0417\u0410 \u0418\u0413\u0420\u0423\n"
